<?xml version="1.0" encoding="UTF-8"?>
<definition:ConnectorDefinition
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:definition="http://www.bonitasoft.org/ns/connector/definition/6.1">
  <id>${dynamics-create-entity.def.id}</id>
  <version>${dynamics-create-entity.def.version}</version>
  <icon>dynamics.png</icon>
  <category icon="dynamics.png" id="Microsoft Dynamics 365"/>

  <!-- Connection inputs -->
  <input name="tenantId" type="java.lang.String" mandatory="true"/>
  <input name="clientId" type="java.lang.String" mandatory="true"/>
  <input name="clientSecret" type="java.lang.String" mandatory="true"/>
  <input name="organizationUrl" type="java.lang.String" mandatory="true"/>
  <input name="apiVersion" type="java.lang.String" mandatory="false" defaultValue="v9.2"/>
  <input name="connectTimeout" type="java.lang.Integer" mandatory="false" defaultValue="30000"/>
  <input name="readTimeout" type="java.lang.Integer" mandatory="false" defaultValue="60000"/>

  <!-- Operation inputs -->
  <input name="entityType" type="java.lang.String" mandatory="true"/>
  <input name="entityData" type="java.lang.String" mandatory="true"/>
  <input name="returnRepresentation" type="java.lang.Boolean" mandatory="false" defaultValue="false"/>

  <!-- Outputs -->
  <output name="success" type="java.lang.Boolean"/>
  <output name="errorMessage" type="java.lang.String"/>
  <output name="entityId" type="java.lang.String"/>
  <output name="entityUrl" type="java.lang.String"/>
  <output name="responseBody" type="java.lang.String"/>

  <!-- Pages -->
  <page id="connectionPage">
    <widget xsi:type="definition:Text" id="tenantIdWidget" inputName="tenantId"/>
    <widget xsi:type="definition:Text" id="clientIdWidget" inputName="clientId"/>
    <widget xsi:type="definition:Password" id="clientSecretWidget" inputName="clientSecret"/>
    <widget xsi:type="definition:Text" id="organizationUrlWidget" inputName="organizationUrl"/>
    <widget xsi:type="definition:Select" id="apiVersionWidget" inputName="apiVersion">
      <items>v9.2</items>
      <items>v9.1</items>
      <items>v9.0</items>
    </widget>
    <widget xsi:type="definition:Text" id="connectTimeoutWidget" inputName="connectTimeout"/>
    <widget xsi:type="definition:Text" id="readTimeoutWidget" inputName="readTimeout"/>
  </page>
  <page id="operationPage">
    <widget xsi:type="definition:Select" id="entityTypeWidget" inputName="entityType">
      <items>accounts</items>
      <items>contacts</items>
      <items>leads</items>
      <items>opportunities</items>
      <items>incidents</items>
      <items>tasks</items>
      <items>emails</items>
      <items>phonecalls</items>
      <items>appointments</items>
    </widget>
    <widget xsi:type="definition:TextArea" id="entityDataWidget" inputName="entityData"/>
    <widget xsi:type="definition:Checkbox" id="returnRepresentationWidget" inputName="returnRepresentation"/>
  </page>
</definition:ConnectorDefinition>
